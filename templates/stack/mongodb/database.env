
# ==================
# MongoDB initiation
# ==================

# Username and password must percent-encode  
# the following characters
#
# :/?#[]@


# Database names must not include the
# the following characters
#
# /\. "$


# Database initiation script

MONGO_INITDB_ROOT_USERNAME='{{{ mongodb.root_username }}}'
MONGO_INITDB_ROOT_PASSWORD='{{{ mongodb.root_password }}}'

# Internal database access for API

MONGODB_USERNAME='{{{ mongodb.admin_username }}}'
MONGODB_PASSWORD='{{{ mongodb.admin_password }}}'

# Admin user for Cerebro API
# Password hash can be generated with: `cerebro tools hash-password`

CEREBRO_ADMIN_NAME='{{{ mongodb.cerebro_admin_name }}}'
CEREBRO_ADMIN_EMAIL='{{{ mongodb.cerebro_admin_email }}}'
CEREBRO_ADMIN_HASHED_PASSWORD='{{{ mongodb.cerebro_admin_password_hashed }}}'

# Service Bot user + service Team for the Faktory lifecycle worker (S3-5 #5).
# The worker logs in as this Bot (role-scoped, long-lived token) and operates
# within the service team's admin database. The password is the configurable
# deploy secret; only its Argon2 hash is stored here.

CEREBRO_SERVICE_BOT_NAME='{{{ mongodb.service_bot_name }}}'
CEREBRO_SERVICE_BOT_EMAIL='{{{ mongodb.service_bot_email }}}'
CEREBRO_SERVICE_BOT_HASHED_PASSWORD='{{{ mongodb.service_bot_password_hashed }}}'
CEREBRO_SERVICE_TEAM_NAME='{{{ mongodb.service_team_name }}}'
CEREBRO_SERVICE_DB_NAME='{{{ mongodb.service_db_name }}}'
CEREBRO_SERVICE_PROJECT_NAME='{{{ mongodb.service_project_name }}}'

# Backup service-user for catalogue backups (S4-2/H1). Auto-provisioned by
# mongo-init with MongoDB's built-in `backup` role (read-only, mongodump of the
# whole instance). The catalogue-backup worker authenticates with these via the
# backup_mongo_uri.secret rendered by `cerebro stack deploy`.

CEREBRO_BACKUP_USERNAME='{{{ mongodb.backup_username }}}'
CEREBRO_BACKUP_PASSWORD='{{{ mongodb.backup_password }}}'
